@model IEnumerable<CertificateSystem.Models.CertificateHistory>
@{
    ViewData["Title"] = "إحصائيات النظام الاحترافية";
}

<div class="container py-5" dir="rtl">
    <div class="d-flex justify-content-between align-items-end mb-5 animate-slide-up">
        <div>
            <h2 class="fw-bold text-main mb-1">لوحة الإحصائيات والنشاط</h2>
            <p class="text-muted mb-0">سجل كامل بجميع عمليات توليد الشهايد وتاريخ الإصدار</p>
        </div>
        <div class="d-flex gap-3">
            <div class="card border-0 shadow-sm p-3 px-4 rounded-4 bg-white text-center">
                <span class="text-muted small d-block mb-1">إجمالي العمليات</span>
                <h3 class="fw-bold text-primary mb-0">@Model.Count()</h3>
            </div>
            <div class="card border-0 shadow-sm p-3 px-4 rounded-4 bg-white text-center">
                <span class="text-muted small d-block mb-1">تم الإرسال</span>
                <h3 class="fw-bold text-success mb-0">@Model.Count(h => h.EmailSent || h.WhatsAppSent)</h3>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-premium rounded-4 overflow-hidden animate-fade-in">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-app border-bottom">
                    <tr>
                        <th class="py-3 px-4 text-muted small fw-bold text-uppercase">اسم الموظف</th>
                        <th class="py-3 px-4 text-muted small fw-bold text-uppercase">تاريخ الإصدار</th>
                        <th class="py-3 px-4 text-muted small fw-bold text-uppercase">التنسيق</th>
                        <th class="py-3 px-4 text-muted small fw-bold text-uppercase text-center">حالة البريد</th>
                        <th class="py-3 px-4 text-muted small fw-bold text-uppercase text-center">حالة الواتساب</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-5 text-center text-muted">لا توجد سجلات حالية</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="py-3 px-4">
                                <div class="fw-bold">@item.EmployeeName</div>
                            </td>
                            <td class="py-3 px-4">
                                <span class="text-muted small">@item.GeneratedAt.ToString("yyyy/MM/dd")</span>
                                <span class="d-block text-muted tiny" style="font-size: 0.7rem;">@item.GeneratedAt.ToString("HH:mm")</span>
                            </td>
                            <td class="py-3 px-4">
                                <span class="badge bg-light text-dark border-0 shadow-sm px-2 py-1">@item.ExportType.ToUpper()</span>
                            </td>
                            <td class="py-3 px-4 text-center">
                                @if (item.EmailSent) { <i class="fa-solid fa-circle-check text-success fs-5"></i> }
                                else { <i class="fa-solid fa-circle-xmark text-danger opacity-25 fs-5"></i> }
                            </td>
                            <td class="py-3 px-4 text-center">
                                @if (item.WhatsAppSent) { <i class="fa-solid fa-circle-check text-success fs-5"></i> }
                                else { <i class="fa-solid fa-circle-xmark text-danger opacity-25 fs-5"></i> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

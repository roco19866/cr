@{
    ViewData["Title"] = "استوديو التصميم - نظام الشهايد";
}

<div class="dashboard-wrapper animate-fade-in" dir="rtl">
    <form asp-action="GenerateCertificates" asp-controller="Home" method="post" enctype="multipart/form-data" class="d-flex w-100">
        <!-- Sidebar Settings -->
        <aside class="settings-sidebar">
            <div class="sidebar-header mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h4 class="fw-bold text-main mb-1">استوديو التصميم</h4>
                        <p class="text-muted small mb-0">تحكم كامل في كل تفاصيل الشهادة</p>
                    </div>
                </div>
            </div>

            <div class="accordion custom-accordion" id="settingsAccordion">
                <!-- 1. Media & Source -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFiles">
                            <i class="fa-solid fa-photo-film me-2 text-primary"></i> 1. الوسائط والبيانات
                        </button>
                    </h2>
                    <div id="collapseFiles" class="accordion-collapse collapse show" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <div class="mb-4">
                                <label class="form-label-premium">قالب الشهادة (صورة)</label>
                                <div class="file-upload-wrapper border rounded-4 p-4 text-center transition-all" onclick="document.getElementById('TemplateFile').click()" style="cursor: pointer; background: var(--bg-app);">
                                    <i class="fa-solid fa-cloud-arrow-up fs-1 mb-2 text-primary opacity-50"></i>
                                    <p class="small mb-0 text-muted">اسحب القالب هنا أو انقر للاختيار</p>
                                    <input type="file" id="TemplateFile" name="TemplateFile" class="d-none" accept="image/*" required onchange="previewImage(event)" />
                                </div>
                            </div>

                            <div class="card border-0 bg-app p-3 rounded-4 mb-3">
                                <label class="form-label-premium text-primary d-flex align-items-center mb-3">
                                    <i class="fa-solid fa-users-gear me-2"></i> مصدر البيانات
                                </label>
                                
                                <div class="search-wrapper-premium mb-3">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                    <input type="text" id="filterSearch" placeholder="بحث بالاسم..." onkeyup="fetchEmployees()">
                                </div>

                                <div class="premium-dropdown mb-3" id="deptDropdown">
                                    <div class="premium-dropdown-selected" onclick="toggleDropdown(event)">
                                        <span id="selectedDeptName">كل الأقسام</span>
                                        <i class="fa-solid fa-chevron-down chevron small opacity-50"></i>
                                    </div>
                                    <div class="premium-dropdown-list">
                                        @foreach (var dept in new[] { "كل الأقسام", "الإدارة العليا", "تقنية المعلومات", "الموارد البشرية", "التسويق", "العمليات" })
                                        {
                                            <div class="premium-dropdown-item @(dept == "كل الأقسام" ? "active" : "")" 
                                                 onclick="selectDepartment(this, '@(dept == "كل الأقسام" ? "" : dept)', '@dept')">
                                                @dept
                                            </div>
                                        }
                                    </div>
                                </div>
                                <input type="hidden" id="filterDepartment" value="">

                                <div id="employeesContainer" class="mt-2" style="max-height: 280px; overflow-y: auto; padding: 4px;">
                                    <div class="text-center py-4 text-muted small">جاري التحميل...</div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center mt-2 px-1">
                                    <div class="small text-muted"><span id="selectedCount" class="fw-bold text-primary">0</span> موظف مختار</div>
                                    <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 small fw-bold" onclick="toggleAllEmployees()">تحديد الكل</button>
                                </div>
                                <input type="hidden" name="SelectedEmployeeIds" id="SelectedEmployeeIds" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Elements & Layers -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseText">
                            <i class="fa-solid fa-layer-group me-2 text-primary"></i> 2. العناصر والطبقات
                        </button>
                    </h2>
                    <div id="collapseText" class="accordion-collapse collapse" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <!-- Name Layer -->
                            <div class="layer-card p-3 border rounded-4 mb-3 bg-app" onclick="focusElement('previewName')">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-user-tag me-1"></i> طبقة الاسم</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked disabled></div>
                                </div>
                                <div class="row g-2 mb-2">
                                    <div class="col-12">
                                        <select name="NameFontFamily" id="NameFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Tajawal">Tajawal (Default)</option>
                                            <option value="Cairo">Cairo</option>
                                            <option value="Arial">Arial</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <input type="number" name="NameFontSize" id="NameFontSize" class="form-control form-control-sm" value="48" oninput="updateDraggableDesign()" />
                                    </div>
                                    <div class="col-6">
                                        <input type="color" name="NameFontColor" id="NameFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#000000" oninput="updateDraggableDesign()" />
                                    </div>
                                    <div class="col-12">
                                        <select name="NameTextAlign" id="NameTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Center">توسيط</option>
                                            <option value="Right">يمين</option>
                                            <option value="Left">يسار</option>
                                        </select>
                                    </div>
                                </div>
                                <input type="hidden" id="NameX" name="NameX" value="500" />
                                <input type="hidden" id="NameY" name="NameY" value="400" />
                            </div>

                            <!-- Civil ID Layer -->
                            <div class="layer-card p-3 border rounded-4 mb-3 bg-app" onclick="focusElement('previewCivil')">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-id-card me-1"></i> طبقة السجل</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleCivil" checked onchange="toggleLayer('previewCivil', this)"></div>
                                </div>
                                <div class="row g-2 mb-2 layer-controls">
                                    <div class="col-12">
                                        <select name="CivilIdFontFamily" id="CivilIdFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Tajawal">Tajawal</option>
                                            <option value="Arial">Arial</option>
                                        </select>
                                    </div>
                                    <div class="col-6"><input type="number" name="CivilIdFontSize" id="CivilIdFontSize" class="form-control form-control-sm" value="32" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><input type="color" name="CivilIdFontColor" id="CivilIdFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#333333" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-12">
                                        <select name="CivilIdTextAlign" id="CivilIdTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Center">توسيط</option>
                                            <option value="Right">يمين</option>
                                            <option value="Left">يسار</option>
                                        </select>
                                    </div>
                                </div>
                                <input type="hidden" id="CivilIdX" name="CivilIdX" value="500" />
                                <input type="hidden" id="CivilIdY" name="CivilIdY" value="500" />
                            </div>

                            <!-- Date Layer -->
                            <div class="layer-card p-3 border rounded-4 mb-3 bg-app" onclick="focusElement('previewDate')">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-calendar-day me-1"></i> طبقة التاريخ</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleDate" checked onchange="toggleLayer('previewDate', this)"></div>
                                </div>
                                <div class="layer-controls">
                                    <input type="text" name="DateText" id="DateText" class="form-control form-control-sm mb-2" value="@DateTime.Now.ToString("yyyy/MM/dd")" oninput="updateText('previewDate', this.value)" />
                                    <div class="row g-2 mb-2">
                                        <div class="col-12">
                                            <select name="DateFontFamily" id="DateFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                                <option value="Tajawal">Tajawal</option>
                                                <option value="Arial">Arial</option>
                                            </select>
                                        </div>
                                        <div class="col-6"><input type="number" name="DateFontSize" id="DateFontSize" class="form-control form-control-sm" value="28" oninput="updateDraggableDesign()" /></div>
                                        <div class="col-6"><input type="color" name="DateFontColor" id="DateFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#555555" oninput="updateDraggableDesign()" /></div>
                                        <div class="col-12">
                                            <select name="DateTextAlign" id="DateTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                                <option value="Center">توسيط</option>
                                                <option value="Right">يمين</option>
                                                <option value="Left">يسار</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" id="DateX" name="DateX" value="800" />
                                <input type="hidden" id="DateY" name="DateY" value="800" />
                            </div>

                            <!-- Additional Text -->
                            <div class="layer-card p-3 border rounded-4 bg-app" onclick="focusElement('previewAdditional')">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold mb-0 small text-primary"><i class="fa-solid fa-align-right me-1"></i> نص إضافي</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleAdditional" onchange="toggleLayer('previewAdditional', this)"></div>
                                </div>
                                <div class="layer-controls opacity-50" id="additionalControls">
                                    <textarea id="AdditionalText" name="AdditionalText" class="form-control form-control-sm mb-2" rows="2" placeholder="اكتب النص هنا..." oninput="updateText('previewAdditional', this.value)"></textarea>
                                    <div class="row g-2">
                                        <div class="col-12">
                                            <select name="AdditionalTextFontFamily" id="AdditionalTextFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                                <option value="Tajawal">Tajawal</option>
                                                <option value="Arial">Arial</option>
                                            </select>
                                        </div>
                                        <div class="col-6"><input type="number" name="AdditionalTextFontSize" id="AdditionalTextFontSize" class="form-control form-control-sm" value="32" oninput="updateDraggableDesign()" /></div>
                                        <div class="col-6"><input type="color" name="AdditionalTextFontColor" id="AdditionalTextFontColor" class="form-control form-control-sm h-auto p-0 border-0" value="#000000" oninput="updateDraggableDesign()" /></div>
                                        <div class="col-12">
                                            <select name="AdditionalTextAlign" id="AdditionalTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                                <option value="Center">توسيط</option>
                                                <option value="Right">يمين</option>
                                                <option value="Left">يسار</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                                <input type="hidden" id="AdditionalTextX" name="AdditionalTextX" value="500" />
                                <input type="hidden" id="AdditionalTextY" name="AdditionalTextY" value="650" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Finalize -->
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExport">
                            <i class="fa-solid fa-file-export me-2 text-primary"></i> 3. التصدير والتحميل
                        </button>
                    </h2>
                    <div id="collapseExport" class="accordion-collapse collapse" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body">
                            <label class="form-label-premium">تنسيق المخرجات</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="ExportType" id="png" value="png" checked>
                                <label class="btn btn-outline-primary py-2" for="png">PNG</label>
                                <input type="radio" class="btn-check" name="ExportType" id="jpg" value="jpg">
                                <label class="btn btn-outline-primary py-2" for="jpg">JPG</label>
                                <input type="radio" class="btn-check" name="ExportType" id="pdf" value="pdf">
                                <label class="btn btn-outline-primary py-2" for="pdf">PDF</label>
                            </div>

                            <div class="mt-4 border-top pt-3">
                                <label class="form-label-premium mb-3 d-block"><i class="fa-solid fa-paper-plane me-1"></i> خيارات الإرسال</label>
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="SendEmail" name="SendEmail" value="true">
                                    <label class="form-check-label small" for="SendEmail">إرسال عبر البريد الإلكتروني</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="SendWhatsApp" name="SendWhatsApp" value="true">
                                    <label class="form-check-label small" for="SendWhatsApp">إرسال عبر الواتساب</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-4 border-top">
                <button type="submit" class="btn btn-premium btn-premium-primary w-100 py-3 shadow-lg animate-pulse-hover">
                    <i class="fa-solid fa-wand-magic-sparkles me-2"></i> توليد الشهايد الآن
                </button>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="workspace-area">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="animate-slide-in">
                    <h4 class="fw-bold text-main mb-0">لوحة التصميم الذكية</h4>
                    <p class="text-muted small">حدد مواقع العناصر بدقة عن طريق السحب</p>
                </div>
                <div class="workspace-tools glass-effect p-2 rounded-4 shadow-sm d-flex align-items-center">
                    <div class="form-check form-switch me-3 pt-1">
                        <input class="form-check-input" type="checkbox" id="fitToggle" onchange="toggleFit()" checked>
                        <label class="form-check-label small fw-bold" for="fitToggle">احتواء</label>
                    </div>
                    <div class="vr mx-2 h-20px"></div>
                    <button type="button" class="btn btn-light btn-sm rounded-3 px-3" onclick="location.reload()" title="إعادة تعيين"><i class="fa-solid fa-rotate-left"></i></button>
                </div>
            </div>

            <div class="preview-container-wrapper shadow-inner">
                <div id="noImageOverlay" class="text-center p-5 animate-fade-in">
                    <div class="mb-4 studio-icon">
                        <i class="fa-solid fa-wand-magic-sparkles text-primary opacity-25" style="font-size: 80px;"></i>
                    </div>
                    <h5 class="text-main fw-bold">ارفع قالبك للبدء</h5>
                    <p class="text-muted small mx-auto" style="max-width: 300px;">بمجرد رفع صورة القالب، ستتمكن من التحكم في جميع العناصر والبيانات مباشرة</p>
                </div>

                <div id="imageContainer" style="position: relative; display: none;" class="animate-scale-in">
                    <img id="imagePreview" src="#" alt="معاينة" class="fit-image shadow-premium rounded-2" />
                    
                    <!-- Draggable Elements -->
                    <div id="previewName" class="draggable-text-premium" data-targetx="NameX" data-targety="NameY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">اسم المتدرب</div>
                    </div>
                    <div id="previewCivil" class="draggable-text-premium" data-targetx="CivilIdX" data-targety="CivilIdY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">1000000000</div>
                    </div>
                    <div id="previewDate" class="draggable-text-premium" data-targetx="DateX" data-targety="DateY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">@DateTime.Now.ToString("yyyy/MM/dd")</div>
                    </div>
                    <div id="previewAdditional" class="draggable-text-premium" data-targetx="AdditionalTextX" data-targety="AdditionalTextY" style="display: none;">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">نص إضافي هنا</div>
                    </div>
                </div>
            </div>
        </main>
    </form>
</div>

<style>
    .fit-image {
        max-width: 100%;
        max-height: 75vh;
        width: auto;
        height: auto;
        object-fit: contain;
        background: white;
    }
    
    .layer-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid var(--border-color) !important;
        cursor: pointer;
    }
    
    .layer-card:hover {
        border-color: var(--primary) !important;
        box-shadow: var(--shadow-md);
        transform: translateY(-2px);
    }
    
    .shadow-inner {
        box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
    }
    
    .animate-pulse-hover:hover i {
        animation: pulse 1s infinite;
    }
    
    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); }
    }
</style>

@section Scripts {
    <script>
        // Dropdown Logic
        function toggleDropdown(e) {
            e.stopPropagation();
            document.getElementById('deptDropdown').classList.toggle('open');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', () => {
            document.getElementById('deptDropdown')?.classList.remove('open');
        });

        function selectDepartment(el, deptId, deptName) {
            document.querySelectorAll('.premium-dropdown-item').forEach(p => p.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('selectedDeptName').innerText = deptName;
            document.getElementById('filterDepartment').value = deptId;
            document.getElementById('deptDropdown').classList.remove('open');
            fetchEmployees();
        }

        // Preview logic
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('imagePreview');
                output.src = reader.result;
                document.getElementById('imageContainer').style.display = 'inline-block';
                document.getElementById('noImageOverlay').style.display = 'none';

                output.onload = function() {
                    document.querySelectorAll('.draggable-text-premium').forEach(function(el) {
                        let toggleId = "toggle" + el.id.replace("preview", "");
                        let toggle = document.getElementById(toggleId);
                        if (!toggle || toggle.checked) el.style.display = 'block';
                        updateOverlayPosFromInputs(el);
                    });
                    updateDraggableDesign();
                };
            }
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        function toggleLayer(previewId, cb) {
            let el = document.getElementById(previewId);
            if (el) el.style.display = cb.checked ? 'block' : 'none';
            let controlsId = cb.id.replace("toggle", "").toLowerCase() + "Controls";
            let controls = document.getElementById(controlsId);
            if(controls) controls.classList.toggle('opacity-50', !cb.checked);
        }

        function updateText(id, val) {
            let el = document.getElementById(id);
            if(el) {
                el.querySelector('.text-content').innerText = val ? val : "(فارغ)";
            }
        }

        function updateOverlayPosFromInputs(el) {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth;
            var scaleY = rect.height / img.naturalHeight;
            var txInput = document.getElementById(el.getAttribute("data-targetx"));
            var tyInput = document.getElementById(el.getAttribute("data-targety"));
            if(!txInput || !tyInput) return;
            el.style.left = (txInput.value * scaleX) + 'px';
            el.style.top = (tyInput.value * scaleY) + 'px';
        }

        function toggleFit() {
            var img = document.getElementById('imagePreview');
            var isFit = document.getElementById('fitToggle').checked;
            img.style.maxWidth = isFit ? '100%' : 'none';
            img.style.maxHeight = isFit ? '75vh' : 'none';
            setTimeout(() => {
                document.querySelectorAll('.draggable-text-premium').forEach(el => {
                   if(el.style.display !== 'none') updateOverlayPosFromInputs(el);
                });
                updateDraggableDesign();
            }, 50);
        }

        // Draggable logic
        let activeEl = null;
        let isDragging = false;
        let startX, startY, initialLeft, initialTop;

        document.querySelectorAll('.draggable-text-premium').forEach(item => {
            item.addEventListener('mousedown', function(e) {
                isDragging = true;
                activeEl = item;
                item.classList.add('active-drag');
                startX = e.clientX;
                startY = e.clientY;
                initialLeft = parseFloat(getComputedStyle(item).left) || 0;
                initialTop = parseFloat(getComputedStyle(item).top) || 0;
                e.preventDefault();
            });
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging || !activeEl) return;
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            activeEl.style.left = (initialLeft + dx) + 'px';
            activeEl.style.top = (initialTop + dy) + 'px';
        });

        document.addEventListener('mouseup', function() {
            if (isDragging && activeEl) {
                activeEl.classList.remove('active-drag');
                var img = document.getElementById('imagePreview');
                var rect = img.getBoundingClientRect();
                var currentLeft = parseFloat(getComputedStyle(activeEl).left) || 0;
                var currentTop = parseFloat(getComputedStyle(activeEl).top) || 0;
                var scaleX = img.naturalWidth / rect.width;
                var scaleY = img.naturalHeight / rect.height;
                document.getElementById(activeEl.getAttribute("data-targetx")).value = Math.round(currentLeft * scaleX);
                document.getElementById(activeEl.getAttribute("data-targety")).value = Math.round(currentTop * scaleY);
            }
            isDragging = false;
            activeEl = null;
        });

        function updateDraggableDesign() {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth || 1;
            let configs = [
                { id: 'previewName', prefix: 'Name' },
                { id: 'previewCivil', prefix: 'CivilId' },
                { id: 'previewDate', prefix: 'Date' },
                { id: 'previewAdditional', prefix: 'AdditionalText' }
            ];
            configs.forEach(conf => {
                let textEl = document.getElementById(conf.id);
                if (textEl) {
                    let content = textEl.querySelector('.text-content');
                    content.style.color = document.getElementById(conf.prefix + 'FontColor')?.value || '#000';
                    content.style.fontFamily = document.getElementById(conf.prefix + 'FontFamily')?.value || 'Tajawal';
                    content.style.textAlign = document.getElementById(conf.prefix + 'TextAlign')?.value || 'center';
                    let rawSize = document.getElementById(conf.prefix + 'FontSize')?.value || 32;
                    content.style.fontSize = (rawSize * scaleX) + 'px';
                }
            });
        }

        function focusElement(id) {
            document.querySelectorAll('.draggable-text-premium').forEach(el => el.classList.remove('active-drag'));
            let el = document.getElementById(id);
            if(el) {
                el.classList.add('active-drag');
                setTimeout(() => el.classList.remove('active-drag'), 1500);
            }
        }

        // Employee logic
        async function fetchEmployees() {
            let search = document.getElementById('filterSearch').value;
            let department = document.getElementById('filterDepartment').value;
            let params = new URLSearchParams({ search: search, department: department });
            try {
                let response = await fetch('/Home/GetEmployees?' + params.toString());
                let data = await response.json();
                renderEmployees(data);
            } catch(e) { console.error(e); }
        }

        function renderEmployees(employees) {
            let container = document.getElementById('employeesContainer');
            container.innerHTML = '';
            if(employees.length === 0) {
                 container.innerHTML = '<div class="text-center py-4 text-muted small">لا يوجد نتائج</div>';
                 return;
            }
            let selectedIds = document.getElementById('SelectedEmployeeIds').value.split(',').filter(id => id);
            
            employees.forEach(emp => {
                let isSelected = selectedIds.includes(emp.id.toString());
                let div = document.createElement('div');
                div.className = `emp-list-item ${isSelected ? 'selected' : ''}`;
                div.setAttribute('data-id', emp.id);
                div.onclick = () => toggleEmployee(div, emp.id);
                div.innerHTML = `
                    <div class="form-check m-0">
                        <input type="checkbox" class="form-check-input" ${isSelected ? 'checked' : ''} onclick="event.stopPropagation()">
                    </div>
                    <div class="ms-3 flex-grow-1">
                        <div class="fw-bold small d-flex justify-content-between">
                            <span>${emp.name}</span>
                            <button type="button" class="btn btn-link btn-sm p-0 text-muted" onclick="event.stopPropagation(); editEmployee(${JSON.stringify(emp)})"><i class="fa-solid fa-pen-to-square"></i></button>
                        </div>
                        <div class="text-muted" style="font-size: 0.7rem;">
                            ${emp.department || 'بدون قسم'} | 
                            <span class="text-primary">${emp.email || 'بدون بريد'}</span>
                        </div>
                    </div>
                    <i class="fa-solid fa-circle-check text-primary ms-2 ${isSelected ? '' : 'd-none'}"></i>
                `;
                container.appendChild(div);
            });
            updateSelectedCount();
        }

        function toggleEmployee(el, id) {
            let cb = el.querySelector('input');
            cb.checked = !cb.checked;
            el.classList.toggle('selected', cb.checked);
            el.querySelector('i').classList.toggle('d-none', !cb.checked);
            updateSelectedIds();
        }

        function editEmployee(emp) {
            let name = prompt("تعديل الاسم:", emp.name);
            let email = prompt("تعديل البريد الإلكتروني:", emp.email || "");
            let phone = prompt("تعديل رقم الجوال:", emp.phone || "");
            if (name !== null) saveEmployee(emp.id, name, email, phone);
        }

        async function saveEmployee(id, name, email, phone) {
            let formData = new FormData();
            formData.append('id', id);
            formData.append('name', name);
            formData.append('email', email);
            formData.append('phone', phone);
            try {
                let response = await fetch('/Home/UpdateEmployee', { method: 'POST', body: formData });
                let res = await response.json();
                if (res.success) fetchEmployees();
                else alert("فشل الحفظ");
            } catch(e) { console.error(e); }
        }

        function updateSelectedIds() {
            let selected = Array.from(document.querySelectorAll('.emp-list-item input:checked'))
                               .map(cb => cb.closest('.emp-list-item').getAttribute('data-id'));
            document.getElementById('SelectedEmployeeIds').value = selected.join(',');
            updateSelectedCount();
        }

        function updateSelectedCount() {
            let count = document.getElementById('SelectedEmployeeIds').value.split(',').filter(id => id).length;
            document.getElementById('selectedCount').innerText = count;
        }

        function toggleAllEmployees() {
            let items = document.querySelectorAll('.emp-list-item');
            let anyUnchecked = Array.from(items).some(item => !item.querySelector('input').checked);
            items.forEach(item => {
                let cb = item.querySelector('input');
                cb.checked = anyUnchecked;
                item.classList.toggle('selected', anyUnchecked);
                item.querySelector('i').classList.toggle('d-none', !anyUnchecked);
            });
            updateSelectedIds();
        }

        fetchEmployees();
    </script>
}

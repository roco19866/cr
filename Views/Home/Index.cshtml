@{
    ViewData["Title"] = "استوديو التصميم الاحترافي";
}

<div class="dashboard-wrapper animate-fade-in" dir="rtl">
    <form asp-action="GenerateCertificates" asp-controller="Home" method="post" enctype="multipart/form-data" class="d-flex w-100 h-100">
        <!-- Sidebar Controls -->
        <aside class="settings-sidebar">
            <div class="sidebar-header mb-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="logo-container" style="background: var(--primary); color: white; width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="fa-solid fa-wand-magic-sparkles"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold text-main mb-0">استوديو التصميم</h5>
                        <p class="text-muted small mb-0">تحكم كامل في القوالب</p>
                    </div>
                </div>
            </div>

            <div class="sidebar-menus" id="settingsMenus">
                <!-- 0. Design Templates Dropdown -->
                <div class="sidebar-dropdown mb-3">
                    <button class="btn dropdown-toggle-premium w-100 d-flex align-items-center justify-content-between" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTemplates">
                        <span><i class="fa-solid fa-bookmark me-2"></i> القوالب المحفوظة</span>
                        <i class="fa-solid fa-chevron-down small opacity-50"></i>
                    </button>
                    <div id="collapseTemplates" class="collapse mt-2">
                        <div class="dropdown-content-box p-3 bg-app rounded-4 border">
                            <div class="mb-3">
                                <div class="input-group">
                                    <input type="text" id="templateName" class="form-control form-control-sm border-end-0" placeholder="اسم القالب الجديد...">
                                    <button class="btn btn-primary btn-sm px-3" type="button" onclick="saveDesignTemplate()">حفظ</button>
                                </div>
                            </div>
                            <div id="templatesList" class="small">
                                <div class="text-center py-2 text-muted">جاري تحميل القوالب...</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 1. Media & Source Dropdown -->
                <div class="sidebar-dropdown mb-3">
                    <button class="btn dropdown-toggle-premium w-100 d-flex align-items-center justify-content-between" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFiles">
                        <span><i class="fa-solid fa-database me-2"></i> 1. البيانات والوسائط</span>
                        <i class="fa-solid fa-chevron-down small opacity-50"></i>
                    </button>
                    <div id="collapseFiles" class="collapse mt-2">
                        <div class="dropdown-content-box p-3 bg-app rounded-4 border">
                            <div class="mb-4">
                                <label class="fw-bold mb-2 small text-primary"><i class="fa-solid fa-image me-1"></i> قالب الشهادة (PNG/JPG)</label>
                                <div class="file-upload-wrapper border-2 border-dashed rounded-4 p-4 text-center transition-all" onclick="document.getElementById('TemplateFile').click()" style="cursor: pointer; background: var(--bg-card); border-color: var(--border-color);">
                                    <i class="fa-solid fa-cloud-arrow-up fs-2 mb-2 text-primary opacity-50"></i>
                                    <p class="small mb-0 text-muted">اسحب الصورة هنا أو تصفح</p>
                                    <input type="file" id="TemplateFile" name="TemplateFile" class="d-none" accept="image/*" required onchange="previewImage(event)" />
                                </div>
                            </div>

                            <div class="card border-0 bg-card p-3 rounded-4 mb-3 shadow-sm">
                                <label class="fw-bold mb-3 small text-primary d-flex align-items-center">
                                    <i class="fa-solid fa-users me-2"></i> اختيار الموظفين
                                </label>
                                
                                <div class="search-wrapper-premium mb-3">
                                    <i class="fa-solid fa-magnifying-glass"></i>
                                    <input type="text" id="filterSearch" placeholder="بحث بالاسم..." onkeyup="fetchEmployees()">
                                </div>

                                <div class="premium-dropdown mb-3" id="deptDropdown">
                                    <div class="premium-dropdown-selected" onclick="toggleDropdown(event)">
                                        <span id="selectedDeptName">كل الأقسام</span>
                                        <i class="fa-solid fa-chevron-down chevron small opacity-50"></i>
                                    </div>
                                    <div class="premium-dropdown-list">
                                        @foreach (var dept in new[] { "كل الأقسام", "الإدارة العليا", "تقنية المعلومات", "الموارد البشرية", "التسويق", "العمليات" })
                                        {
                                            <div class="premium-dropdown-item @(dept == "كل الأقسام" ? "active" : "")" 
                                                 onclick="selectDepartment(this, '@(dept == "كل الأقسام" ? "" : dept)', '@dept')">
                                                @dept
                                            </div>
                                        }
                                    </div>
                                </div>
                                <input type="hidden" id="filterDepartment" value="">

                                <div id="employeesContainer" class="mt-2" style="max-height: 250px; overflow-y: auto; padding-left: 5px;">
                                    <div class="text-center py-4 text-muted small">جاري التحميل...</div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center mt-3 border-top pt-2">
                                    <div class="small text-muted"><span id="selectedCount" class="fw-bold text-primary">0</span> مختار</div>
                                    <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 small fw-bold" onclick="toggleAllEmployees()">تحديد الكل</button>
                                </div>
                                <input type="hidden" name="SelectedEmployeeIds" id="SelectedEmployeeIds" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Elements Dropdown -->
                <div class="sidebar-dropdown mb-3">
                    <button class="btn dropdown-toggle-premium w-100 d-flex align-items-center justify-content-between" type="button" data-bs-toggle="collapse" data-bs-target="#collapseText">
                        <span><i class="fa-solid fa-layers me-2"></i> 2. تنسيق العناصر</span>
                        <i class="fa-solid fa-chevron-down small opacity-50"></i>
                    </button>
                    <div id="collapseText" class="collapse mt-2">
                        <div class="dropdown-content-box p-3 bg-app rounded-4 border">
                            <!-- Name Layer -->
                            <div class="layer-card shadow-sm mb-3" onclick="focusElement('previewName')">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 small"><i class="fa-solid fa-font me-2 text-primary"></i> نص الاسم</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" checked disabled></div>
                                </div>
                                <div class="row g-2">
                                    <div class="col-12 mb-1">
                                        <select name="NameFontFamily" id="NameFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Tajawal">Tajawal (Default)</option>
                                            <option value="Cairo">Cairo</option>
                                            <option value="Arial">Arial</option>
                                        </select>
                                    </div>
                                    <div class="col-6"><input type="number" name="NameFontSize" id="NameFontSize" class="form-control form-control-sm" value="48" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><input type="color" name="NameFontColor" id="NameFontColor" class="form-control form-control-sm h-auto p-1" value="#000000" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-12"><button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="snapToCenter('NameX', 'NameY', 'previewName')">توسيط</button></div>
                                </div>
                                <input type="hidden" id="NameX" name="NameX" value="500" />
                                <input type="hidden" id="NameY" name="NameY" value="400" />
                                <input type="hidden" id="NameTextAlign" name="NameTextAlign" value="Center" />
                            </div>

                            <!-- Civil ID Layer -->
                            <div class="layer-card shadow-sm mb-3" onclick="focusElement('previewCivil')">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 small"><i class="fa-solid fa-id-card me-2 text-primary"></i> السجل المدني</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleCivil" checked onchange="toggleLayer('previewCivil', this)"></div>
                                </div>
                                <div class="row g-2">
                                    <div class="col-12 mb-1">
                                        <select name="CivilIdFontFamily" id="CivilIdFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()">
                                            <option value="Tajawal">Tajawal</option>
                                            <option value="Arial">Arial</option>
                                        </select>
                                    </div>
                                    <div class="col-6"><input type="number" name="CivilIdFontSize" id="CivilIdFontSize" class="form-control form-control-sm" value="32" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><input type="color" name="CivilIdFontColor" id="CivilIdFontColor" class="form-control form-control-sm h-auto p-1" value="#333333" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-12"><button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="snapToCenter('CivilIdX', 'CivilIdY', 'previewCivil')">توسيط</button></div>
                                </div>
                                <input type="hidden" id="CivilIdX" name="CivilIdX" value="500" />
                                <input type="hidden" id="CivilIdY" name="CivilIdY" value="500" />
                                <input type="hidden" id="CivilIdTextAlign" name="CivilIdTextAlign" value="Center" />
                            </div>

                            <!-- Date Layer -->
                            <div class="layer-card shadow-sm" onclick="focusElement('previewDate')">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h6 class="fw-bold mb-0 small"><i class="fa-solid fa-calendar me-2 text-primary"></i> التاريخ</h6>
                                    <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" id="toggleDate" checked onchange="toggleLayer('previewDate', this)"></div>
                                </div>
                                <input type="text" name="DateText" id="DateText" class="form-control form-control-sm mb-2" value="@DateTime.Now.ToString("yyyy/MM/dd")" oninput="updateText('previewDate', this.value)" />
                                <div class="row g-2">
                                    <div class="col-6"><input type="number" name="DateFontSize" id="DateFontSize" class="form-control form-control-sm" value="28" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><input type="color" name="DateFontColor" id="DateFontColor" class="form-control form-control-sm h-auto p-1" value="#555555" oninput="updateDraggableDesign()" /></div>
                                </div>
                                <input type="hidden" id="DateX" name="DateX" value="800" />
                                <input type="hidden" id="DateY" name="DateY" value="800" />
                                <input type="hidden" id="DateFontFamily" name="DateFontFamily" value="Tajawal" />
                                <input type="hidden" id="DateTextAlign" name="DateTextAlign" value="Center" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Export Dropdown -->
                <div class="sidebar-dropdown mb-3">
                    <button class="btn dropdown-toggle-premium w-100 d-flex align-items-center justify-content-between" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExport">
                        <span><i class="fa-solid fa-share-nodes me-2"></i> 3. خيارات التصدير</span>
                        <i class="fa-solid fa-chevron-down small opacity-50"></i>
                    </button>
                    <div id="collapseExport" class="collapse mt-2">
                        <div class="dropdown-content-box p-3 bg-app rounded-4 border">
                            <div class="btn-group w-100 mb-4" role="group">
                                <input type="radio" class="btn-check" name="ExportType" id="png" value="png" checked>
                                <label class="btn btn-outline-primary" for="png">PNG</label>
                                <input type="radio" class="btn-check" name="ExportType" id="pdf" value="pdf">
                                <label class="btn btn-outline-primary" for="pdf">PDF</label>
                            </div>

                            <div class="options-group p-3 bg-card rounded-4 border shadow-sm">
                                <h6 class="fw-bold small mb-3"><i class="fa-solid fa-paper-plane me-1"></i> الإرسال التلقائي</h6>
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="SendEmail" name="SendEmail" value="true">
                                    <label class="form-check-label small" for="SendEmail">عبر البريد</label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="SendWhatsApp" name="SendWhatsApp" value="true">
                                    <label class="form-check-label small" for="SendWhatsApp">عبر الواتساب</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="sidebar-footer mt-auto pt-4">
                <button type="submit" id="submitBtn" class="btn btn-premium btn-premium-primary w-100 shadow-lg">
                    <span class="btn-content">توليد الشهايد الآن</span>
                    <span class="btn-loading d-none"><i class="fa-solid fa-spinner fa-spin me-2"></i> جاري العمل...</span>
                </button>
            </div>
        </aside>

        <!-- Main Workspace -->
        <main class="workspace-area">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="workspace-header">
                    <h4 class="fw-bold text-main mb-1">منصة التصميم الذكية</h4>
                    <p class="text-muted small mb-0">قم بسحب العناصر لتحديد مواقعها بدقة</p>
                </div>
                <div class="workspace-tools shadow-sm">
                    <div class="d-flex align-items-center gap-2">
                        <div class="form-check form-switch m-0 pt-1 border-end pe-3">
                            <input class="form-check-input" type="checkbox" id="fitToggle" onchange="toggleFit()" checked>
                            <label class="form-check-label small fw-bold" for="fitToggle">احتواء</label>
                        </div>
                        <button type="button" class="btn btn-light btn-sm rounded-circle shadow-none" onclick="location.reload()" title="إعادة تعيين"><i class="fa-solid fa-rotate-left"></i></button>
                    </div>
                </div>
            </div>

            <div class="preview-container-wrapper">
                <div id="noImageOverlay" class="text-center p-5">
                    <div class="mb-4 text-primary opacity-25">
                        <i class="fa-solid fa-image" style="font-size: 100px;"></i>
                    </div>
                    <h5 class="fw-bold">ابدأ برفع قالب الشهادة</h5>
                    <p class="text-muted small">بمجرد الرفع، ستظهر أدوات التحكم هنا</p>
                    <button type="button" class="btn btn-primary rounded-pill px-4" onclick="document.getElementById('TemplateFile').click()">اختيار صورة القالب</button>
                </div>

                <div id="imageContainer" style="position: relative; display: none;" class="animate-fade-in">
                    <img id="imagePreview" src="#" alt="Certificate Template" class="fit-image shadow-premium" style="max-width: 100%; max-height: 80vh; border-radius: 4px;" />
                    
                    <!-- Draggable Elements -->
                    <div id="previewName" class="draggable-text-premium" data-targetx="NameX" data-targety="NameY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">اسم المتدرب</div>
                    </div>
                    <div id="previewCivil" class="draggable-text-premium" data-targetx="CivilIdX" data-targety="CivilIdY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">1000000000</div>
                    </div>
                    <div id="previewDate" class="draggable-text-premium" data-targetx="DateX" data-targety="DateY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">@DateTime.Now.ToString("yyyy/MM/dd")</div>
                    </div>
                </div>
            </div>
        </main>
    </form>
</div>

@section Scripts {
    <script>
        // Form Handling
        document.querySelector('form').addEventListener('submit', function() {
            const btn = document.getElementById('submitBtn');
            btn.classList.add('disabled');
            btn.querySelector('.btn-content').classList.add('d-none');
            btn.querySelector('.btn-loading').classList.remove('d-none');
        });

        // Dropdown Toggle
        function toggleDropdown(e) {
            e.stopPropagation();
            document.getElementById('deptDropdown').classList.toggle('open');
        }

        document.addEventListener('click', () => {
            document.getElementById('deptDropdown')?.classList.remove('open');
        });

        function selectDepartment(el, deptId, deptName) {
            document.querySelectorAll('.premium-dropdown-item').forEach(p => p.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('selectedDeptName').innerText = deptName;
            document.getElementById('filterDepartment').value = deptId;
            document.getElementById('deptDropdown').classList.remove('open');
            fetchEmployees();
        }

        // Image Preview and Initial Setup
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('imagePreview');
                output.src = reader.result;
                document.getElementById('imageContainer').style.display = 'inline-block';
                document.getElementById('noImageOverlay').style.display = 'none';

                output.onload = function() {
                    document.querySelectorAll('.draggable-text-premium').forEach(function(el) {
                        let toggleId = "toggle" + el.id.replace("preview", "");
                        let toggle = document.getElementById(toggleId);
                        if (!toggle || toggle.checked) el.style.display = 'block';
                        updateOverlayPosFromInputs(el);
                    });
                    updateDraggableDesign();
                };
            }
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        function toggleLayer(previewId, cb) {
            let el = document.getElementById(previewId);
            if (el) el.style.display = cb.checked ? 'block' : 'none';
        }

        function updateText(id, val) {
            let el = document.getElementById(id);
            if(el) {
                el.querySelector('.text-content').innerText = val ? val : "(فارغ)";
            }
        }

        function updateOverlayPosFromInputs(el) {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth;
            var scaleY = rect.height / img.naturalHeight;
            var txInput = document.getElementById(el.getAttribute("data-targetx"));
            var tyInput = document.getElementById(el.getAttribute("data-targety"));
            if(!txInput || !tyInput) return;
            el.style.left = (txInput.value * scaleX) + 'px';
            el.style.top = (tyInput.value * scaleY) + 'px';
        }

        function toggleFit() {
            var img = document.getElementById('imagePreview');
            var isFit = document.getElementById('fitToggle').checked;
            img.style.maxWidth = isFit ? '100%' : 'none';
            img.style.maxHeight = isFit ? '80vh' : 'none';
            setTimeout(() => {
                document.querySelectorAll('.draggable-text-premium').forEach(el => {
                   if(el.style.display !== 'none') updateOverlayPosFromInputs(el);
                });
                updateDraggableDesign();
            }, 50);
        }

        // Draggable Functionality
        let activeEl = null;
        let isDragging = false;
        let startX, startY, initialLeft, initialTop;

        document.querySelectorAll('.draggable-text-premium').forEach(item => {
            item.addEventListener('mousedown', function(e) {
                isDragging = true;
                activeEl = item;
                item.classList.add('active-drag');
                startX = e.clientX;
                startY = e.clientY;
                initialLeft = parseFloat(getComputedStyle(item).left) || 0;
                initialTop = parseFloat(getComputedStyle(item).top) || 0;
                e.preventDefault();
            });
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging || !activeEl) return;
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            activeEl.style.left = (initialLeft + dx) + 'px';
            activeEl.style.top = (initialTop + dy) + 'px';
        });

        document.addEventListener('mouseup', function() {
            if (isDragging && activeEl) {
                activeEl.classList.remove('active-drag');
                var img = document.getElementById('imagePreview');
                var rect = img.getBoundingClientRect();
                var currentLeft = parseFloat(getComputedStyle(activeEl).left) || 0;
                var currentTop = parseFloat(getComputedStyle(activeEl).top) || 0;
                var scaleX = img.naturalWidth / rect.width;
                var scaleY = img.naturalHeight / rect.height;
                document.getElementById(activeEl.getAttribute("data-targetx")).value = Math.round(currentLeft * scaleX);
                document.getElementById(activeEl.getAttribute("data-targety")).value = Math.round(currentTop * scaleY);
            }
            isDragging = false;
            activeEl = null;
        });

        function updateDraggableDesign() {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth || 1;
            let configs = [
                { id: 'previewName', prefix: 'Name' },
                { id: 'previewCivil', prefix: 'CivilId' },
                { id: 'previewDate', prefix: 'Date' }
            ];
            configs.forEach(conf => {
                let textEl = document.getElementById(conf.id);
                if (textEl) {
                    let content = textEl.querySelector('.text-content');
                    content.style.color = document.getElementById(conf.prefix + 'FontColor')?.value || '#000';
                    content.style.fontFamily = document.getElementById(conf.prefix + 'FontFamily')?.value || 'Tajawal';
                    let rawSize = document.getElementById(conf.prefix + 'FontSize')?.value || 32;
                    content.style.fontSize = (rawSize * scaleX) + 'px';
                }
            });
        }

        function snapToCenter(xInputId, yInputId, previewId) {
            var img = document.getElementById('imagePreview');
            if(!img.naturalWidth) return;
            document.getElementById(xInputId).value = Math.round(img.naturalWidth / 2);
            document.getElementById(yInputId).value = Math.round(img.naturalHeight / 2);
            updateOverlayPosFromInputs(document.getElementById(previewId));
            updateDraggableDesign();
        }

        // Employee and Template Management
        async function fetchEmployees() {
            let search = document.getElementById('filterSearch').value;
            let department = document.getElementById('filterDepartment').value;
            let params = new URLSearchParams({ search: search, department: department });
            try {
                let response = await fetch('/Home/GetEmployees?' + params.toString());
                let data = await response.json();
                renderEmployees(data);
            } catch(e) { console.error(e); }
        }

        function renderEmployees(employees) {
            let container = document.getElementById('employeesContainer');
            container.innerHTML = '';
            if(employees.length === 0) {
                 container.innerHTML = '<div class="text-center py-4 text-muted small">لا يوجد نتائج</div>';
                 return;
            }
            let selectedIds = document.getElementById('SelectedEmployeeIds').value.split(',').filter(id => id);
            employees.forEach(emp => {
                let isSelected = selectedIds.includes(emp.id.toString());
                let div = document.createElement('div');
                div.className = `emp-list-item ${isSelected ? 'selected' : ''}`;
                div.setAttribute('data-id', emp.id);
                div.onclick = () => toggleEmployee(div, emp.id);
                div.innerHTML = `
                    <div class="form-check m-0"><input type="checkbox" class="form-check-input" ${isSelected ? 'checked' : ''} onclick="event.stopPropagation()"></div>
                    <div class="ms-3 flex-grow-1">
                        <div class="fw-bold small">${emp.name}</div>
                        <div class="text-muted" style="font-size: 0.7rem;">${emp.department || 'بدون قسم'}</div>
                    </div>
                `;
                container.appendChild(div);
            });
            updateSelectedCount();
        }

        function toggleEmployee(el, id) {
            let cb = el.querySelector('input');
            cb.checked = !cb.checked;
            el.classList.toggle('selected', cb.checked);
            updateSelectedIds();
        }

        function updateSelectedIds() {
            let selected = Array.from(document.querySelectorAll('.emp-list-item input:checked'))
                               .map(cb => cb.closest('.emp-list-item').getAttribute('data-id'));
            document.getElementById('SelectedEmployeeIds').value = selected.join(',');
            updateSelectedCount();
        }

        function updateSelectedCount() {
            let count = document.getElementById('SelectedEmployeeIds').value.split(',').filter(id => id).length;
            document.getElementById('selectedCount').innerText = count;
        }

        function toggleAllEmployees() {
            let items = document.querySelectorAll('.emp-list-item');
            let anyUnchecked = Array.from(items).some(item => !item.querySelector('input').checked);
            items.forEach(item => {
                let cb = item.querySelector('input');
                cb.checked = anyUnchecked;
                item.classList.toggle('selected', anyUnchecked);
            });
            updateSelectedIds();
        }

        async function fetchTemplates() {
            try {
                let response = await fetch('/api/Templates');
                let templates = await response.json();
                renderTemplates(templates);
            } catch(e) { console.error(e); }
        }

        function renderTemplates(templates) {
            let container = document.getElementById('templatesList');
            container.innerHTML = '';
            if (templates.length === 0) {
                container.innerHTML = '<div class="text-center py-2 text-muted">لا يوجد قوالب</div>';
                return;
            }
            templates.forEach(t => {
                let div = document.createElement('div');
                div.className = 'd-flex justify-content-between align-items-center mb-1 p-2 border rounded-3 bg-light';
                div.innerHTML = `
                    <span class="fw-bold cursor-pointer" onclick='loadDesignTemplate(${t.configJson})'>${t.name}</span>
                    <button class="btn btn-link btn-sm text-danger p-0" onclick="deleteTemplate(${t.id})"><i class="fa-solid fa-trash-can"></i></button>
                `;
                container.appendChild(div);
            });
        }

        async function saveDesignTemplate() {
            let name = document.getElementById('templateName').value;
            if (!name) return;
            let config = {};
            ['NameFontSize', 'NameFontColor', 'NameFontFamily', 'NameX', 'NameY',
             'CivilIdFontSize', 'CivilIdFontColor', 'CivilIdFontFamily', 'CivilIdX', 'CivilIdY',
             'DateFontSize', 'DateFontColor', 'DateX', 'DateY'].forEach(id => {
                let el = document.getElementById(id);
                if(el) config[id] = el.value;
            });
            try {
                await fetch('/api/Templates', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name: name, configJson: JSON.stringify(config) })
                });
                document.getElementById('templateName').value = '';
                fetchTemplates();
            } catch(e) { console.error(e); }
        }

        function loadDesignTemplate(config) {
            for (let key in config) {
                let el = document.getElementById(key);
                if (el) { el.value = config[key]; if (el.oninput) el.oninput(); }
            }
            document.querySelectorAll('.draggable-text-premium').forEach(el => updateOverlayPosFromInputs(el));
            updateDraggableDesign();
        }

        async function deleteTemplate(id) {
            if (!confirm("حذف القالب؟")) return;
            try {
                await fetch('/api/Templates/' + id, { method: 'DELETE' });
                fetchTemplates();
            } catch(e) { console.error(e); }
        }

        // Initialization
        fetchEmployees();
        fetchTemplates();
    </script>
}

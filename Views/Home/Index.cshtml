@{
    ViewData["Title"] = "لوحة التحكم - نظام الشهايد";
}

<div class="dashboard-wrapper" dir="rtl">
    <form asp-action="GenerateCertificates" asp-controller="Home" method="post" enctype="multipart/form-data" class="d-flex w-100">
        <!-- Sidebar Settings -->
        <aside class="settings-sidebar shadow-sm">
            <div class="sidebar-header mb-4">
                <h4 class="fw-bold text-dark mb-1"><i class="fa-solid fa-sliders me-2 text-primary"></i> إعدادات الشهادة</h4>
                <p class="text-muted small">قم بضبط الملفات والنصوص بدقة</p>
            </div>

            <div class="accordion custom-accordion" id="settingsAccordion">
                <!-- 1. Files & Template -->
                <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden">
                    <h2 class="accordion-header">
                        <button class="accordion-button bg-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFiles">
                            <i class="fa-solid fa-file-import me-2 text-primary"></i> 1. القالب والملفات
                        </button>
                    </h2>
                    <div id="collapseFiles" class="accordion-collapse collapse show" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body bg-light-50">
                            <div class="mb-3">
                                <label class="form-label-premium">صورة القالب (JPG/PNG)</label>
                                <div class="input-group">
                                    <input type="file" id="TemplateFile" name="TemplateFile" class="form-control form-control-premium" accept="image/*" required onchange="previewImage(event)" />
                                </div>
                            </div>

                            <div class="employee-source-box p-3 bg-white border rounded-4 mb-3">
                                <label class="form-label-premium text-primary"><i class="fa-solid fa-users-gear me-1"></i> مصدر الموظفين (قاعدة البيانات)</label>
                                <div class="row g-2 mb-2">
                                    <div class="col-12">
                                        <input type="text" id="filterSearch" class="form-control form-control-sm form-control-premium" placeholder="بحث بالاسم..." onkeyup="fetchEmployees()">
                                    </div>
                                    <div class="col-12">
                                        <select id="filterDepartment" class="form-select form-select-sm form-control-premium" onchange="fetchEmployees()">
                                            <option value="">كل الإدارات والأقسام</option>
                                            <option value="الإدارة العليا">الإدارة العليا</option>
                                            <option value="تقنية المعلومات">تقنية المعلومات</option>
                                            <option value="الموارد البشرية">الموارد البشرية</option>
                                            <option value="التسويق">التسويق</option>
                                            <option value="العمليات">العمليات</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <select id="filterGender" class="form-select form-select-sm form-control-premium" onchange="fetchEmployees()">
                                            <option value="">الجنس</option>
                                            <option value="ذكر">ذكر</option>
                                            <option value="أنثى">أنثى</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <select id="filterRole" class="form-select form-select-sm form-control-premium" onchange="fetchEmployees()">
                                            <option value="">الوظيفة</option>
                                            <option value="مدير">مدير</option>
                                            <option value="رئيس قسم">رئيس قسم</option>
                                            <option value="موظف">موظف</option>
                                            <option value="سائق">سائق</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="table-responsive bg-white rounded-3 border" style="max-height: 180px; overflow-y: auto;">
                                    <table class="table table-sm table-hover mb-0" style="font-size: 0.85rem;">
                                        <thead class="bg-light sticky-top">
                                            <tr>
                                                <th width="40"><input type="checkbox" id="selectAllEmployees" onchange="toggleAllEmployees(this)" class="form-check-input"></th>
                                                <th>الاسم</th>
                                                <th>القسم</th>
                                            </tr>
                                        </thead>
                                        <tbody id="employeesTableBody">
                                            <tr><td colspan="3" class="text-center py-3 text-muted">جاري التحميل...</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                                <input type="hidden" name="SelectedEmployeeIds" id="SelectedEmployeeIds" />
                            </div>

                            <div class="excel-source-box p-3 bg-white border rounded-4">
                                <label class="form-label-premium text-success"><i class="fa-solid fa-file-excel me-1"></i> مصدر الإكسيل (اختياري)</label>
                                <input type="file" name="ExcelFile" class="form-control form-control-premium" accept=".xlsx, .xls" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. Text Design -->
                <div class="accordion-item border-0 mb-3 shadow-sm rounded-4 overflow-hidden">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseText">
                            <i class="fa-solid fa-font me-2 text-success"></i> 2. تصميم النصوص
                        </button>
                    </h2>
                    <div id="collapseText" class="accordion-collapse collapse" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body bg-light-50">
                            <!-- Additional Text -->
                            <div class="text-config-card p-3 bg-white border rounded-4 mb-3">
                                <h6 class="fw-bold mb-3 border-bottom pb-2">النص الثابت</h6>
                                <textarea id="AdditionalText" name="AdditionalText" class="form-control form-control-premium mb-2" rows="2" placeholder="أدخل النص هنا..." oninput="updateText('previewAdditional', this.value)"></textarea>
                                <div class="row g-2">
                                    <div class="col-6"><label class="small fw-bold">الخط:</label><select name="AdditionalTextFontFamily" id="AdditionalTextFontFamily" class="form-select form-select-sm" onchange="updateDraggableDesign()"><option value="Arial">Arial</option><option value="Tajawal">Tajawal</option><option value="Tahoma">Tahoma</option></select></div>
                                    <div class="col-6"><label class="small fw-bold">الحجم:</label><input type="number" name="AdditionalTextFontSize" id="AdditionalTextFontSize" class="form-control form-control-sm" value="32" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><label class="small fw-bold">اللون:</label><input type="color" name="AdditionalTextFontColor" id="AdditionalTextFontColor" class="form-control form-control-sm h-auto py-1" value="#000000" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><label class="small fw-bold">المحاذاة:</label><select name="AdditionalTextAlign" id="AdditionalTextAlign" class="form-select form-select-sm" onchange="updateDraggableDesign()"><option value="Center">توسيط</option><option value="Right">يمين</option></select></div>
                                </div>
                                <div class="row g-2 mt-2">
                                    <div class="col-6"><input type="number" id="AdditionalTextX" name="AdditionalTextX" class="form-control form-control-sm" placeholder="X" oninput="manualSync('previewAdditional')" /></div>
                                    <div class="col-6"><input type="number" id="AdditionalTextY" name="AdditionalTextY" class="form-control form-control-sm" placeholder="Y" oninput="manualSync('previewAdditional')" /></div>
                                </div>
                            </div>

                            <!-- Name Variable -->
                            <div class="text-config-card p-3 bg-white border rounded-4 mb-3">
                                <h6 class="fw-bold mb-3 border-bottom pb-2 text-primary">مكان الاسم</h6>
                                <div class="row g-2">
                                    <div class="col-6"><label class="small fw-bold">الحجم:</label><input type="number" name="NameFontSize" id="NameFontSize" class="form-control form-control-sm" value="48" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><label class="small fw-bold">اللون:</label><input type="color" name="NameFontColor" id="NameFontColor" class="form-control form-control-sm h-auto py-1" value="#000000" oninput="updateDraggableDesign()" /></div>
                                    <div class="col-6"><input type="number" id="NameX" name="NameX" class="form-control form-control-sm" placeholder="X" oninput="manualSync('previewName')" /></div>
                                    <div class="col-6"><input type="number" id="NameY" name="NameY" class="form-control form-control-sm" placeholder="Y" oninput="manualSync('previewName')" /></div>
                                </div>
                            </div>

                            <!-- Date Variable -->
                            <div class="text-config-card p-3 bg-white border rounded-4">
                                <h6 class="fw-bold mb-3 border-bottom pb-2">مكان التاريخ</h6>
                                <input type="text" id="DateText" name="DateText" class="form-control form-control-sm mb-2" value="@DateTime.Now.ToString("yyyy/MM/dd")" oninput="updateText('previewDate', this.value)" />
                                <div class="row g-2">
                                    <div class="col-6"><input type="number" id="DateX" name="DateX" class="form-control form-control-sm" placeholder="X" oninput="manualSync('previewDate')" /></div>
                                    <div class="col-6"><input type="number" id="DateY" name="DateY" class="form-control form-control-sm" placeholder="Y" oninput="manualSync('previewDate')" /></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. Export -->
                <div class="accordion-item border-0 mb-4 shadow-sm rounded-4 overflow-hidden">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed bg-white fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExport">
                            <i class="fa-solid fa-download me-2 text-warning"></i> 3. التصدير والتحميل
                        </button>
                    </h2>
                    <div id="collapseExport" class="accordion-collapse collapse" data-bs-parent="#settingsAccordion">
                        <div class="accordion-body bg-light-50">
                            <label class="form-label-premium">صيغة الملف</label>
                            <select name="ExportType" class="form-select form-control-premium mb-3">
                                <option value="png">PNG (صور عالية الجودة)</option>
                                <option value="jpg">JPG (صور مضغوطة)</option>
                                <option value="pdf">PDF (ملف وثيقة)</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-premium-primary w-100 py-3 shadow-lg">
                <i class="fa-solid fa-wand-magic-sparkles me-2"></i> توليد الشهايد الآن
            </button>
        </aside>

        <!-- Main Workspace -->
        <main class="workspace-area">
            <div class="workspace-header d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold text-dark mb-0">مساحة التصميم الذكية</h3>
                    <p class="text-muted small mb-0">اسحب النصوص وأفلتها لتحديد المكان بدقة على الشهادة</p>
                </div>
                <div class="workspace-tools bg-white p-2 rounded-4 shadow-sm d-flex align-items-center">
                    <div class="form-check form-switch me-3 pt-1">
                        <input class="form-check-input" type="checkbox" id="fitToggle" onchange="toggleFit()" checked>
                        <label class="form-check-label small fw-bold" for="fitToggle">احتواء كامل</label>
                    </div>
                    <div class="vr mx-2 h-20px"></div>
                    <button type="button" class="btn btn-light btn-sm rounded-3" onclick="location.reload()"><i class="fa-solid fa-rotate-left"></i></button>
                </div>
            </div>

            <div class="preview-container-wrapper glass-morphism">
                <div id="noImageOverlay" class="text-center p-5">
                    <div class="mb-4">
                        <i class="fa-solid fa-image text-muted opacity-25" style="font-size: 80px;"></i>
                    </div>
                    <h5 class="text-muted fw-bold">لم يتم رفع قالب بعد</h5>
                    <p class="text-muted small">قم برفع صورة القالب من القائمة الجانبية للبدء</p>
                </div>

                <div id="imageContainer" style="position: relative; display: none;">
                    <img id="imagePreview" src="#" alt="معاينة" class="fit-image shadow-lg rounded-2" />
                    
                    <!-- Draggable Elements -->
                    <div id="previewName" class="draggable-text-premium" data-targetx="NameX" data-targety="NameY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">اسم المتدرب</div>
                    </div>
                    <div id="previewCivil" class="draggable-text-premium" data-targetx="CivilIdX" data-targety="CivilIdY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">1234567890</div>
                    </div>
                    <div id="previewAdditional" class="draggable-text-premium" data-targetx="AdditionalTextX" data-targety="AdditionalTextY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">النص الإضافي</div>
                    </div>
                    <div id="previewDate" class="draggable-text-premium" data-targetx="DateX" data-targety="DateY">
                        <span class="drag-handle"><i class="fa-solid fa-arrows-up-down-left-right"></i></span>
                        <div class="text-content">@DateTime.Now.ToString("yyyy/MM/dd")</div>
                    </div>
                </div>
            </div>
        </main>
    </form>
</div>

<style>
    .draggable-text-premium {
        position: absolute;
        cursor: move;
        user-select: none;
        display: none;
        padding: 5px 10px;
        transform: translate(-50%, -50%);
        white-space: pre-wrap;
        text-align: center;
        min-width: max-content;
        line-height: 1.2;
        border: 2px solid transparent;
        border-radius: 8px;
        transition: border-color 0.2s, background-color 0.2s;
    }

    .draggable-text-premium:hover {
        border-color: var(--primary-color);
        background: rgba(255, 255, 255, 0.6);
    }

    .draggable-text-premium .drag-handle {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--primary-color);
        color: white;
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 10px;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .draggable-text-premium:hover .drag-handle {
        opacity: 1;
    }

    .fit-image {
        max-width: 100%;
        max-height: 80vh;
        width: auto;
        height: auto;
        object-fit: contain;
    }

    .custom-accordion .accordion-button:not(.collapsed) {
        background-color: rgba(0, 170, 149, 0.05);
        color: var(--primary-color);
        box-shadow: none;
    }

    .h-20px { height: 20px; }
    
    .glass-morphism {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }
</style>

@section Scripts {
    <script>
        let currentScale = 1;

        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function() {
                var output = document.getElementById('imagePreview');
                output.src = reader.result;
                document.getElementById('imageContainer').style.display = 'inline-block';
                document.getElementById('noImageOverlay').style.display = 'none';

                output.onload = function() {
                    document.querySelectorAll('.draggable-text-premium').forEach(function(el) {
                        el.style.display = 'block';
                        updateOverlayPosFromInputs(el);
                    });
                    updateDraggableDesign();
                };
            }
            if (event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }

        function updateText(id, val) {
            let el = document.getElementById(id);
            if(el) {
                el.querySelector('.text-content').innerText = val ? val : "(فارغ)";
            }
        }

        function updateOverlayPosFromInputs(el) {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth;
            var scaleY = rect.height / img.naturalHeight;

            var txInput = document.getElementById(el.getAttribute("data-targetx"));
            var tyInput = document.getElementById(el.getAttribute("data-targety"));
            
            if(!txInput || !tyInput) return;

            var tx = txInput.value;
            var ty = tyInput.value;

            el.style.left = (tx * scaleX) + 'px';
            el.style.top = (ty * scaleY) + 'px';
        }

        function manualSync(previewId) {
            let el = document.getElementById(previewId);
            if(el) updateOverlayPosFromInputs(el);
        }

        function toggleFit() {
            var img = document.getElementById('imagePreview');
            var isFit = document.getElementById('fitToggle').checked;
            
            if (isFit) {
                img.style.maxWidth = '100%';
                img.style.maxHeight = '80vh';
            } else {
                img.style.maxWidth = 'none';
                img.style.maxHeight = 'none';
            }
            
            setTimeout(() => {
                document.querySelectorAll('.draggable-text-premium').forEach(el => updateOverlayPosFromInputs(el));
                updateDraggableDesign();
            }, 100);
        }

        // --- Draggable Logic ---
        let activeEl = null;
        let isDragging = false;
        let startX, startY, initialLeft, initialTop;

        document.querySelectorAll('.draggable-text-premium').forEach(item => {
            item.addEventListener('mousedown', function(e) {
                isDragging = true;
                activeEl = item;
                startX = e.clientX;
                startY = e.clientY;
                initialLeft = parseFloat(getComputedStyle(item).left) || 0;
                initialTop = parseFloat(getComputedStyle(item).top) || 0;
                e.preventDefault();
            });
        });

        document.addEventListener('mousemove', function(e) {
            if (!isDragging || !activeEl) return;
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            activeEl.style.left = (initialLeft + dx) + 'px';
            activeEl.style.top = (initialTop + dy) + 'px';
        });

        document.addEventListener('mouseup', function() {
            if (isDragging && activeEl) {
                var img = document.getElementById('imagePreview');
                var rect = img.getBoundingClientRect();
                var currentLeft = parseFloat(getComputedStyle(activeEl).left) || 0;
                var currentTop = parseFloat(getComputedStyle(activeEl).top) || 0;
                var scaleX = img.naturalWidth / rect.width;
                var scaleY = img.naturalHeight / rect.height;

                var realX = Math.round(currentLeft * scaleX);
                var realY = Math.round(currentTop * scaleY);

                document.getElementById(activeEl.getAttribute("data-targetx")).value = realX;
                document.getElementById(activeEl.getAttribute("data-targety")).value = realY;
            }
            isDragging = false;
            activeEl = null;
        });

        window.addEventListener('resize', () => {
            document.querySelectorAll('.draggable-text-premium').forEach(function(el) {
                if(el.style.display == 'block') updateOverlayPosFromInputs(el);
            });
        });

        function updateDraggableDesign() {
            var img = document.getElementById('imagePreview');
            var rect = img.getBoundingClientRect();
            var scaleX = rect.width / img.naturalWidth || 1;

            let mapOptions = [
                { id: 'previewName', prefix: 'Name' },
                { id: 'previewCivil', prefix: 'CivilId' },
                { id: 'previewDate', prefix: 'Date' },
                { id: 'previewAdditional', prefix: 'AdditionalText' }
            ];

            mapOptions.forEach(op => {
                let textEl = document.getElementById(op.id);
                if (textEl) {
                    let content = textEl.querySelector('.text-content');
                    content.style.color = document.getElementById(op.prefix + 'FontColor')?.value || '#000';
                    content.style.fontFamily = document.getElementById(op.prefix + 'FontFamily')?.value || 'Arial';
                    let rawSize = document.getElementById(op.prefix + 'FontSize')?.value || 32;
                    content.style.fontSize = (rawSize * scaleX) + 'px';
                    
                    let alignValue = document.getElementById(op.prefix + 'TextAlign')?.value || 'Center';
                    let textAlignMap = { 'Right': 'right', 'Left': 'left', 'Center': 'center' };
                    content.style.textAlign = textAlignMap[alignValue];
                }
            });
        }

        // --- DBAJAX Logic ---
        let loadedEmployees = [];
        let currentlySelectedIds = new Set();
        
        async function fetchEmployees() {
            let search = document.getElementById('filterSearch').value;
            let gender = document.getElementById('filterGender').value;
            let role = document.getElementById('filterRole').value;
            let department = document.getElementById('filterDepartment').value;
            
            let params = new URLSearchParams({ search: search, gender: gender, role: role, department: department });
            try {
                let response = await fetch('/Home/GetEmployees?' + params.toString());
                loadedEmployees = await response.json();
                renderEmployeesTable();
            } catch(e) { console.error(e); }
        }
        
        function renderEmployeesTable() {
            let tbody = document.getElementById('employeesTableBody');
            tbody.innerHTML = '';
            if(loadedEmployees.length === 0) {
                 tbody.innerHTML = '<tr><td colspan="3" class="text-center text-muted py-3">لا يوجد نتائج</td></tr>';
                 return;
            }
            loadedEmployees.forEach(emp => {
                let isChecked = currentlySelectedIds.has(emp.id) ? 'checked' : '';
                let tr = document.createElement('tr');
                tr.innerHTML = `
                    <td><input type="checkbox" class="emp-checkbox form-check-input" value="${emp.id}" onchange="updateSelectedSet(this)" ${isChecked}></td>
                    <td>${emp.name}</td>
                    <td>${emp.department || '-'}</td>
                `;
                tbody.appendChild(tr);
            });
            syncSelectAllUI();
        }
        
        function updateSelectedSet(cb) {
            let id = parseInt(cb.value);
            if(cb.checked) currentlySelectedIds.add(id);
            else currentlySelectedIds.delete(id);
            updateHiddenInput();
            syncSelectAllUI();
        }
        
        function toggleAllEmployees(mainCb) {
            let cbs = document.querySelectorAll('.emp-checkbox');
            cbs.forEach(cb => {
                cb.checked = mainCb.checked;
                let id = parseInt(cb.value);
                if(mainCb.checked) currentlySelectedIds.add(id);
                else currentlySelectedIds.delete(id);
            });
            updateHiddenInput();
        }
        
        function syncSelectAllUI() {
            let cbs = document.querySelectorAll('.emp-checkbox');
            let mainCb = document.getElementById('selectAllEmployees');
            if(cbs.length === 0) { mainCb.checked = false; return; }
            mainCb.checked = Array.from(cbs).every(c => c.checked);
        }
        
        function updateHiddenInput() {
            document.getElementById('SelectedEmployeeIds').value = Array.from(currentlySelectedIds).join(',');
        }
    </script>
}
